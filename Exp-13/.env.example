# Optional single URL format:
# DATABASE_URL=mysql+pymysql://root:your_password@localhost:3306/student_db
# DATABASE_URL=postgresql+psycopg2://user:password@host:5432/database_name

# Optional app port for local run:
# PORT=10000

# Individual MySQL variables:
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_password
MYSQL_DB=student_db
